{
  "name": "fuse-local-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Test harness that demonstrates Cloudflare Containers FUSE is broken in local dev, and that a Docker API proxy workaround fixes it.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "proxy": "node proxy/index.js",
    "dev:with-proxy": "node proxy/with-docker-proxy.js -- wrangler dev",
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.2",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.83.0"
  }
}
